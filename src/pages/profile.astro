---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import BarcodeScannerModal from '../components/BarcodeScannerModal.astro'
import { db as prisma } from '../lib/prisma'

// Vérifier l'authentification côté serveur (version simplifiée)
let user = null
let isAuthenticated = false

try {
  // Récupérer le token depuis les cookies
  const token = Astro.cookies.get('vinyl_vault_token')?.value
  console.log('Profile: Token trouvé:', !!token)

  // Système d'authentification simplifié - récupérer le premier utilisateur
  // (comme dans l'API me.ts et les autres pages)
  // Récupérer l'utilisateur même sans token pour debug
  user = await prisma.user.findFirst({
    orderBy: {
      createdAt: 'desc',
    },
    select: {
      id: true,
      email: true,
      name: true,
      username: true,
      avatar: true,
      createdAt: true,
    },
  })

  isAuthenticated = !!user
  console.log(
    'Profile: Utilisateur trouvé:',
    user ? `${user.id} - ${user.email} - ${user.name}` : 'aucun'
  )
} catch (error) {
  console.error("Erreur d'authentification:", error)
  isAuthenticated = false
}

// Rediriger vers login si non authentifié
if (!isAuthenticated) {
  return Astro.redirect('/login?redirect=' + encodeURIComponent(Astro.url.pathname))
}
