---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { db as prisma } from "../lib/prisma";

const title = "Mes Statistiques - VinylVault";
const description = "Consultez vos statistiques personnelles et l'évolution de votre collection";

// Vérifier l'authentification
let currentUser: { id: string; name: string | null; email: string } | null = null;
let userStats: any = null;
let error: string | null = null;

try {
  // Système d'authentification simplifié - récupérer le premier utilisateur
  currentUser = await prisma.user.findFirst({
    orderBy: { createdAt: 'desc' },
    select: { id: true, name: true, email: true },
  });

  if (currentUser) {
    // Récupérer les statistiques de l'utilisateur
    const userCollections = await prisma.collection.findMany({
      where: { userId: currentUser.id },
      include: {
        vinyls: {
          orderBy: { createdAt: 'desc' }
        }
      }
    });

    const allVinyls = userCollections.flatMap(collection => collection.vinyls);
    
    // Calculer les statistiques
    const totalVinyls = allVinyls.length;
    const totalCollections = userCollections.length;
    const totalValue = allVinyls.reduce((sum, vinyl) => sum + (vinyl.price || 0), 0);
    
    // Top artistes
    const artistCounts: { [key: string]: number } = {};
    allVinyls.forEach(vinyl => {
      artistCounts[vinyl.artist] = (artistCounts[vinyl.artist] || 0) + 1;
    });
    const topArtists = Object.entries(artistCounts)
      .map(([name, count]) => ({ name, count: count as number }))
      .sort((a, b) => b.count - a.count)
      .slice(0, 10);

    // Répartition par format
    const formatCounts: { [key: string]: number } = {};
    allVinyls.forEach(vinyl => {
      const format = vinyl.format || 'Inconnu';
      formatCounts[format] = (formatCounts[format] || 0) + 1;
    });
    const formatBreakdown = Object.entries(formatCounts)
      .map(([format, count]) => ({
        format,
        count: count as number,
        percentage: Math.round(((count as number) / totalVinyls) * 100)
      }))
      .sort((a, b) => b.count - a.count);

    // Répartition par état
    const conditionCounts: { [key: string]: number } = {};
    allVinyls.forEach(vinyl => {
      const condition = vinyl.condition || 'Inconnu';
      conditionCounts[condition] = (conditionCounts[condition] || 0) + 1;
    });
    const conditionBreakdown = Object.entries(conditionCounts)
      .map(([condition, count]) => ({
        condition,
        count: count as number,
        percentage: Math.round(((count as number) / totalVinyls) * 100)
      }))
      .sort((a, b) => b.count - a.count);

    // Évolution dans le temps (par mois)
    const monthlyStats: { [key: string]: number } = {};
    allVinyls.forEach(vinyl => {
      const month = new Date(vinyl.createdAt).toISOString().substring(0, 7); // YYYY-MM
      monthlyStats[month] = (monthlyStats[month] || 0) + 1;
    });
    const timelineData = Object.entries(monthlyStats)
      .map(([month, count]) => ({ month, count: count as number }))
      .sort((a, b) => a.month.localeCompare(b.month));

    userStats = {
      totalVinyls,
      totalCollections,
      totalValue,
      averageValue: totalVinyls > 0 ? totalValue / totalVinyls : 0,
      topArtists,
      formatBreakdown,
      conditionBreakdown,
      timelineData
    };
  }
} catch (err) {
  console.error("Erreur lors de la récupération des statistiques:", err);
  error = "Erreur lors du chargement des statistiques";
}
---

<BaseLayout title={title} description={description}>
  <Navbar slot="navbar" />

  <div class="container mx-auto px-4 py-8">
    {error ? (
      <div class="text-center py-12">
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-8 max-w-md mx-auto">
          <div class="text-red-600 dark:text-red-400 mb-4">
            <svg class="mx-auto h-12 w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h2 class="text-xl font-semibold text-red-800 dark:text-red-200 mb-2">
            Erreur
          </h2>
          <p class="text-red-700 dark:text-red-300 mb-4">
            {error}
          </p>
          <a 
            href="/dashboard" 
            class="inline-flex items-center px-4 py-2 bg-gradient-emerald dark:bg-gradient-emerald text-white rounded-xl hover:bg-gradient-emerald/80 dark:hover:bg-gradient-emerald/80 transition-colors"
          >
            Retour au tableau de bord
          </a>
        </div>
      </div>
    ) : currentUser && userStats ? (
      <>
        <!-- En-tête -->
        <div class="glass dark:glass-dark rounded-xl shadow-sm mb-8 p-6">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-50 mb-2">
                Mes Statistiques
              </h1>
              <p class="text-neutral-600 dark:text-neutral-400">
                Consultez l'évolution de votre collection de vinyles
              </p>
            </div>
            <div class="flex items-center gap-4">
              <a 
                href="/dashboard"
                class="flex items-center gap-2 px-4 py-2 text-neutral-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-500 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Retour au dashboard
              </a>
            </div>
          </div>
        </div>

        <!-- Statistiques générales -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <div class="glass dark:glass-dark rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-neutral-600 dark:text-neutral-400">Total Vinyles</p>
                <p class="text-3xl font-bold text-neutral-900 dark:text-neutral-50">{userStats.totalVinyls}</p>
              </div>
              <div class="p-3 bg-emerald-100 dark:bg-emerald-900/20 rounded-lg">
                <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="glass dark:glass-dark rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-neutral-600 dark:text-neutral-400">Collections</p>
                <p class="text-3xl font-bold text-neutral-900 dark:text-neutral-50">{userStats.totalCollections}</p>
              </div>
              <div class="p-3 bg-blue-100 dark:bg-blue-900/20 rounded-lg">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14-5v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2z"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="glass dark:glass-dark rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-neutral-600 dark:text-neutral-400">Valeur Totale</p>
                <p class="text-3xl font-bold text-neutral-900 dark:text-neutral-50">{Math.round(userStats.totalValue)} €</p>
              </div>
              <div class="p-3 bg-amber-100 dark:bg-amber-900/20 rounded-lg">
                <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="glass dark:glass-dark rounded-xl p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-neutral-600 dark:text-neutral-400">Prix Moyen</p>
                <p class="text-3xl font-bold text-neutral-900 dark:text-neutral-50">{Math.round(userStats.averageValue)} €</p>
              </div>
              <div class="p-3 bg-purple-100 dark:bg-purple-900/20 rounded-lg">
                <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
          <!-- Top Artistes -->
          <div class="glass dark:glass-dark rounded-xl shadow-sm p-6">
            <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50 mb-6">
              Top Artistes
            </h3>
            <div class="space-y-4">
              {userStats.topArtists.map((artist: any, index: number) => (
                <div class="flex items-center justify-between p-3 rounded-lg bg-neutral-50 dark:bg-neutral-800/50">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-gradient-emerald text-white rounded-full flex items-center justify-center text-sm font-bold">
                      {index + 1}
                    </div>
                    <span class="font-medium text-neutral-900 dark:text-neutral-50">{artist.name}</span>
                  </div>
                  <span class="px-3 py-1 bg-neutral-200 dark:bg-neutral-700 text-neutral-900 dark:text-neutral-50 rounded-full text-sm font-medium">
                    {artist.count}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <!-- Répartition par Format -->
          <div class="glass dark:glass-dark rounded-xl shadow-sm p-6">
            <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50 mb-6">
              Répartition par Format
            </h3>
            <div class="space-y-4">
              {userStats.formatBreakdown.map((format: any) => (
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-medium text-neutral-900 dark:text-neutral-50">{format.format}</span>
                    <span class="text-sm text-neutral-600 dark:text-neutral-400">
                      {format.count} ({format.percentage}%)
                    </span>
                  </div>
                  <div class="w-full bg-neutral-200 dark:bg-neutral-700 rounded-full h-2">
                    <div 
                      class="bg-gradient-emerald h-2 rounded-full transition-all duration-500"
                      style={`width: ${format.percentage}%`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Évolution dans le temps -->
        {userStats.timelineData.length > 0 && (
          <div class="glass dark:glass-dark rounded-xl shadow-sm p-6 mt-8">
            <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50 mb-6">
              Évolution de votre collection
            </h3>
            <div class="overflow-x-auto">
              <div class="flex gap-4 pb-4">
                {userStats.timelineData.map((data: any, index: number) => (
                  <div class="flex-shrink-0 text-center">
                    <div class="w-16 h-16 bg-gradient-emerald rounded-lg flex items-center justify-center mb-2">
                      <span class="text-white font-bold text-sm">{data.count}</span>
                    </div>
                    <p class="text-xs text-neutral-600 dark:text-neutral-400">
                      {new Date(data.month + '-01').toLocaleDateString('fr-FR', { 
                        month: 'short', 
                        year: '2-digit' 
                      })}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        <!-- Répartition par État -->
        <div class="glass dark:glass-dark rounded-xl shadow-sm p-6 mt-8">
          <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50 mb-6">
            État de vos vinyles
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {userStats.conditionBreakdown.map((condition: any) => (
              <div class="p-4 rounded-lg bg-neutral-50 dark:bg-neutral-800/50">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-medium text-neutral-900 dark:text-neutral-50">{condition.condition}</span>
                  <span class="text-sm text-neutral-600 dark:text-neutral-400">
                    {condition.count} ({condition.percentage}%)
                  </span>
                </div>
                <div class="w-full bg-neutral-200 dark:bg-neutral-700 rounded-full h-2">
                  <div 
                    class="bg-gradient-emerald h-2 rounded-full transition-all duration-500"
                    style={`width: ${condition.percentage}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </>
    ) : (
      <div class="text-center py-12">
        <div class="inline-flex items-center">
          <svg class="animate-spin h-8 w-8 text-gradient-emerald dark:text-gradient-emerald mr-3" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-lg text-neutral-600 dark:text-neutral-400">Chargement des statistiques...</span>
        </div>
      </div>
    )}
  </div>

  <Footer slot="footer" />
</BaseLayout>
