---
export interface Props {
  currentFilters?: {
    listened?: string // 'all' | 'listened' | 'not-listened'
    rating?: string // 'all' | '1' | '2' | '3' | '4' | '5'
    format?: string
    condition?: string
    genre?: string
  }
  showListenedFilter?: boolean
  showRatingFilter?: boolean
  class?: string
}

const {
  currentFilters = {},
  showListenedFilter = true,
  showRatingFilter = true,
  class: className = '',
} = Astro.props
---

<div
  class={`vinyl-filters bg-white dark:bg-neutral-800 rounded-xl p-4 shadow-sm border border-neutral-200 dark:border-neutral-700 ${className}`}
>
  <div class="flex flex-wrap gap-4 items-center">
    <h3 class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Filtres :</h3>

    {/* Filtre par statut d'écoute */}
    {
      showListenedFilter && (
        <div class="flex items-center gap-2">
          <label for="listened-filter" class="text-sm text-neutral-600 dark:text-neutral-400">
            Écoute :
          </label>
          <select
            id="listened-filter"
            name="listened"
            class="text-sm px-3 py-1.5 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-emerald-300 focus:border-emerald-400"
            value={currentFilters.listened || 'all'}
          >
            <option value="all">Tous</option>
            <option value="listened">Écoutés</option>
            <option value="not-listened">Non écoutés</option>
          </select>
        </div>
      )
    }

    {/* Filtre par note */}
    {
      showRatingFilter && (
        <div class="flex items-center gap-2">
          <label for="rating-filter" class="text-sm text-neutral-600 dark:text-neutral-400">
            Note min :
          </label>
          <select
            id="rating-filter"
            name="rating"
            class="text-sm px-3 py-1.5 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-amber-300 focus:border-amber-400"
            value={currentFilters.rating || 'all'}
          >
            <option value="all">Toutes</option>
            <option value="5">⭐⭐⭐⭐⭐ 5 étoiles</option>
            <option value="4">⭐⭐⭐⭐ 4+ étoiles</option>
            <option value="3">⭐⭐⭐ 3+ étoiles</option>
            <option value="2">⭐⭐ 2+ étoiles</option>
            <option value="1">⭐ 1+ étoile</option>
          </select>
        </div>
      )
    }

    {/* Filtre par format */}
    <div class="flex items-center gap-2">
      <label for="format-filter" class="text-sm text-neutral-600 dark:text-neutral-400">
        Format :
      </label>
      <select
        id="format-filter"
        name="format"
        class="text-sm px-3 py-1.5 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400"
        value={currentFilters.format || 'all'}
      >
        <option value="all">Tous</option>
        <option value="LP">LP</option>
        <option value="EP">EP</option>
        <option value="Single">Single</option>
        <option value='12"'>12"</option>
        <option value='7"'>7"</option>
      </select>
    </div>

    {/* Filtre par condition */}
    <div class="flex items-center gap-2">
      <label for="condition-filter" class="text-sm text-neutral-600 dark:text-neutral-400">
        État :
      </label>
      <select
        id="condition-filter"
        name="condition"
        class="text-sm px-3 py-1.5 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-blue-300 focus:border-blue-400"
        value={currentFilters.condition || 'all'}
      >
        <option value="all">Tous</option>
        <option value="Mint">Mint</option>
        <option value="Near Mint">Near Mint</option>
        <option value="Very Good Plus">Very Good Plus</option>
        <option value="Very Good">Very Good</option>
        <option value="Good Plus">Good Plus</option>
        <option value="Good">Good</option>
      </select>
    </div>

    {/* Bouton de réinitialisation */}
    <button
      type="button"
      id="reset-filters"
      class="text-sm px-3 py-1.5 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 border border-neutral-300 dark:border-neutral-600 rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-300"
    >
      Réinitialiser
    </button>
  </div>

  {/* Indicateurs de filtres actifs */}
  <div id="active-filters" class="mt-3 flex flex-wrap gap-2 empty:hidden">
    <!-- Les filtres actifs seront ajoutés ici par JavaScript -->
  </div>
</div>

<script>
  import { announceToScreenReader } from '../utils/accessibility-helpers'

  document.addEventListener('DOMContentLoaded', () => {
    const filterSelects = document.querySelectorAll('.vinyl-filters select')
    const resetButton = document.getElementById('reset-filters')
    const activeFiltersContainer = document.getElementById('active-filters')

    // Gestion des changements de filtres
    filterSelects.forEach((select) => {
      select.addEventListener('change', (e) => {
        const filterName = (e.target as HTMLSelectElement).name
        const filterValue = (e.target as HTMLSelectElement).value

        // Déclencher l'événement de filtrage
        document.dispatchEvent(
          new CustomEvent('vinyl-filter-change', {
            detail: {
              filter: filterName,
              value: filterValue,
              allFilters: getCurrentFilters(),
            },
          })
        )

        // Mettre à jour l'affichage des filtres actifs
        updateActiveFiltersDisplay()

        // Annoncer le changement aux lecteurs d'écran
        if (filterValue !== 'all') {
          announceToScreenReader(
            `Filtre ${getFilterLabel(filterName)} appliqué : ${getValueLabel(filterName, filterValue)}`
          )
        } else {
          announceToScreenReader(`Filtre ${getFilterLabel(filterName)} supprimé`)
        }
      })
    })

    // Réinitialisation des filtres
    resetButton?.addEventListener('click', () => {
      filterSelects.forEach((select) => {
        ;(select as HTMLSelectElement).value = 'all'
      })

      // Déclencher l'événement de réinitialisation
      document.dispatchEvent(
        new CustomEvent('vinyl-filters-reset', {
          detail: { allFilters: getCurrentFilters() },
        })
      )

      updateActiveFiltersDisplay()
      announceToScreenReader('Tous les filtres ont été réinitialisés')
    })

    // Initialiser l'affichage des filtres actifs
    updateActiveFiltersDisplay()
  })

  function getCurrentFilters() {
    const filters: Record<string, string> = {}
    const selects = document.querySelectorAll(
      '.vinyl-filters select'
    ) as NodeListOf<HTMLSelectElement>

    selects.forEach((select) => {
      if (select.value !== 'all') {
        filters[select.name] = select.value
      }
    })

    return filters
  }

  function updateActiveFiltersDisplay() {
    const container = document.getElementById('active-filters')
    if (!container) return

    const activeFilters = getCurrentFilters()
    const filterKeys = Object.keys(activeFilters)

    if (filterKeys.length === 0) {
      container.innerHTML = ''
      container.classList.add('empty:hidden')
      return
    }

    container.classList.remove('empty:hidden')
    container.innerHTML = filterKeys
      .map((key) => {
        const value = activeFilters[key]
        const label = getFilterLabel(key)
        const valueLabel = getValueLabel(key, value)

        return `
        <span class="inline-flex items-center gap-1 px-2 py-1 text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full">
          ${label}: ${valueLabel}
          <button 
            type="button" 
            class="hover:bg-blue-200 dark:hover:bg-blue-800 rounded-full p-0.5 ml-1"
            onclick="removeFilter('${key}')"
            aria-label="Supprimer le filtre ${label}"
          >
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </span>
      `
      })
      .join('')
  }

  function getFilterLabel(filterName: string): string {
    const labels: Record<string, string> = {
      listened: 'Écoute',
      rating: 'Note',
      format: 'Format',
      condition: 'État',
      genre: 'Genre',
    }
    return labels[filterName] || filterName
  }

  function getValueLabel(filterName: string, value: string): string {
    const labels: Record<string, Record<string, string>> = {
      listened: {
        listened: 'Écoutés',
        'not-listened': 'Non écoutés',
      },
      rating: {
        '5': '5 étoiles',
        '4': '4+ étoiles',
        '3': '3+ étoiles',
        '2': '2+ étoiles',
        '1': '1+ étoile',
      },
    }

    return labels[filterName]?.[value] || value
  }

  // Fonction globale pour supprimer un filtre
  ;(window as any).removeFilter = function (filterName: string) {
    const select = document.querySelector(`select[name="${filterName}"]`) as HTMLSelectElement
    if (select) {
      select.value = 'all'
      select.dispatchEvent(new Event('change'))
    }
  }
</script>

<style>
  /* Améliorer l'apparence des selects */
  select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
    padding-right: 2.5rem;
    appearance: none;
  }

  .dark select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%9ca3af' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
  }
</style>
