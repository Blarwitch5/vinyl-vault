---
import Modal from './ui/Modal.astro'
---

<Modal id="delete-vinyl-modal" size="md" animation="scale">
  <div slot="title" class="flex items-center space-x-3">
    <div
      class="w-10 h-10 bg-red-100 dark:bg-red-900/20 rounded-full flex items-center justify-center"
    >
      <svg
        class="w-5 h-5 text-red-600 dark:text-red-400"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
    </div>
    <div>
      <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-50">Supprimer le vinyle</h2>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">Cette action est irréversible</p>
    </div>
  </div>

  <!-- Contenu principal -->
  <div class="space-y-4">
    <!-- Informations du vinyle à supprimer -->
    <div id="vinyl-info" class="bg-neutral-100 dark:bg-neutral-800 rounded-xl p-4">
      <div class="flex items-center space-x-4">
        <img
          id="vinyl-cover"
          src="/default-vinyl-cover.svg"
          alt="Couverture du vinyle"
          class="w-16 h-16 object-cover rounded-lg shadow-sm"
        />
        <div class="flex-1">
          <h4 id="vinyl-title" class="font-semibold text-neutral-900 dark:text-neutral-50 text-lg">
            Titre de l'album
          </h4>
          <p id="vinyl-artist" class="text-neutral-600 dark:text-neutral-400 text-sm">
            Nom de l'artiste
          </p>
          <div id="vinyl-details" class="text-xs text-neutral-500 dark:text-neutral-500 mt-1">
            <!-- Détails supplémentaires -->
          </div>
        </div>
      </div>
    </div>

    <div class="text-center">
      <p class="text-neutral-700 dark:text-neutral-300">
        Êtes-vous sûr de vouloir supprimer <strong id="vinyl-title-confirm">ce vinyle</strong> de votre
        collection ?
      </p>
      <p class="font-semibold text-red-600 dark:text-red-400 text-sm mt-2">
        Cette action est irréversible.
      </p>
    </div>

    <!-- Message d'erreur -->
    <div id="delete-vinyl-error" class="hidden">
      <div
        class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4"
      >
        <div class="flex items-center space-x-2">
          <svg
            class="w-5 h-5 text-red-600 dark:text-red-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span id="delete-error-message" class="text-red-600 dark:text-red-400"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div slot="footer" class="flex gap-3">
    <button
      data-modal-close
      class="flex-1 px-4 py-3 glass dark:glass-dark text-neutral-900 dark:text-neutral-50 rounded-xl hover:bg-white/80 dark:hover:bg-neutral-900/80 transition-colors"
    >
      Annuler
    </button>
    <button
      id="confirm-delete-vinyl"
      class="flex-1 px-4 py-3 bg-red-600 text-white rounded-xl hover:bg-red-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <span id="delete-text">Supprimer</span>
      <span id="delete-loading" class="hidden">
        <svg
          class="w-4 h-4 animate-spin mx-auto"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
          ></path>
        </svg>
      </span>
    </button>
  </div>
</Modal>

<script>
  import { modalManager } from '../utils/modal-manager'

  // Éléments DOM
  const modal = document.getElementById('delete-vinyl-modal')
  const confirmBtn = document.getElementById('confirm-delete-vinyl')
  const deleteText = document.getElementById('delete-text')
  const deleteLoading = document.getElementById('delete-loading')
  const errorDiv = document.getElementById('delete-vinyl-error')
  const errorMessage = document.getElementById('delete-error-message')

  // Éléments pour afficher les informations du vinyle
  const vinylCover = document.getElementById('vinyl-cover')
  const vinylTitle = document.getElementById('vinyl-title')
  const vinylArtist = document.getElementById('vinyl-artist')
  const vinylDetails = document.getElementById('vinyl-details')
  const vinylTitleConfirm = document.getElementById('vinyl-title-confirm')

  let currentVinylId: string | null = null
  let currentCollectionId: string | null = null

  // Ouvrir la modal
  function openDeleteVinylModal(vinyl: any) {
    console.log('Ouverture de la modal avec les données:', vinyl)
    currentVinylId = vinyl.id
    currentCollectionId = vinyl.collectionId || null

    // Afficher les informations du vinyle
    if (vinylCover) {
      ;(vinylCover as HTMLImageElement).src = vinyl.coverImage || '/default-vinyl-cover.svg'
      ;(vinylCover as HTMLImageElement).alt = vinyl.title || 'Couverture du vinyle'
    }

    if (vinylTitle) {
      vinylTitle.textContent = vinyl.title || 'Titre inconnu'
    }

    if (vinylArtist) {
      vinylArtist.textContent = vinyl.artist || 'Artiste inconnu'
    }

    if (vinylDetails) {
      const details = []
      if (vinyl.year) details.push(vinyl.year)
      if (vinyl.format) details.push(vinyl.format)
      if (vinyl.condition) details.push(vinyl.condition)
      if (vinyl.price) details.push(vinyl.price.toFixed(2) + ' €')

      vinylDetails.textContent = details.join(' • ')
    }

    if (vinylTitleConfirm) {
      vinylTitleConfirm.textContent = vinyl.title || 'ce vinyle'
    }

    // Ouvrir la modal via le gestionnaire
    modalManager.openModal('delete-vinyl-modal')

    hideError()
    setDeleteButtonState(false)
  }

  // Gérer l'état du bouton de suppression
  function setDeleteButtonState(loading: boolean) {
    if (loading) {
      confirmBtn?.setAttribute('disabled', 'true')
      deleteText?.classList.add('hidden')
      deleteLoading?.classList.remove('hidden')
    } else {
      confirmBtn?.removeAttribute('disabled')
      deleteText?.classList.remove('hidden')
      deleteLoading?.classList.add('hidden')
    }
  }

  // Afficher une erreur
  function showError(message: string) {
    if (errorMessage) {
      errorMessage.textContent = message
    }
    errorDiv?.classList.remove('hidden')
  }

  // Masquer l'erreur
  function hideError() {
    errorDiv?.classList.add('hidden')
  }

  // Supprimer le vinyle
  async function deleteVinyl() {
    if (!currentVinylId) return

    setDeleteButtonState(true)
    hideError()

    try {
      const response = await fetch('/api/collections/remove', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({ vinylId: currentVinylId }),
      })

      const data = await response.json()

      if (response.ok && data.success) {
        modalManager.closeModal('delete-vinyl-modal')
        // Rediriger vers la collection ou le dashboard
        if (currentCollectionId) {
          window.location.href = `/collection/${currentCollectionId}`
        } else {
          window.location.href = '/dashboard'
        }
      } else {
        showError(data.error || 'Erreur lors de la suppression du vinyle')
      }
    } catch (error) {
      console.error('Erreur lors de la suppression du vinyle :', error)
      showError('Erreur de connexion')
    } finally {
      setDeleteButtonState(false)
    }
  }

  // Événements
  confirmBtn?.addEventListener('click', deleteVinyl)

  // Écouter les événements personnalisés pour ouvrir la modal
  document.addEventListener('modal:delete-vinyl:open', (event: Event) => {
    const customEvent = event as CustomEvent
    openDeleteVinylModal(customEvent.detail.vinyl)
  })

  // Exposer la fonction globalement
  ;(window as any).openDeleteVinylModal = openDeleteVinylModal
</script>
