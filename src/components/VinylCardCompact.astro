---
import { StarRating, ListenedCheckbox } from './ui'

export interface Props {
  vinyl: {
    id: string
    title: string
    artist: string
    year?: number
    format?: string
    coverImage?: string
    condition?: string
    price?: number
    note?: string
    discogsId?: string
    discogsUrl?: string
    // Nouveaux champs
    listened?: boolean
    userRating?: number
    listenedAt?: string | Date
  }
  showActions?: boolean
  showViewOnly?: boolean
  isInCollection?: boolean
}

const { vinyl, showActions = false, showViewOnly = false } = Astro.props

// Debug: vérifier les props reçues
console.log('VinylCardCompact props:', { showActions, showViewOnly, vinylId: vinyl.id })
const defaultCover = '/default-vinyl-cover.svg'
---

<!-- Pre-fetch de la page de détail du vinyle -->
<link rel="prefetch" href={`/vinyl/${vinyl.id}`} />

<div
  class="vinyl-card-compact glass dark:glass-dark dark:bg-neutral-950 dark:bg-gradient-emerald-subtle rounded-lg shadow-sm dark:shadow-white overflow-hidden hover:shadow-md dark:hover:shadow-white-md transition-all duration-300 hover:scale-105 hover:-translate-y-1 group cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-300 focus:ring-offset-2"
  data-vinyl-id={vinyl.id}
  data-discogs-id={vinyl.discogsId}
  data-discogs-url={vinyl.discogsUrl}
  onclick="handleVinylCardClick(event, this)"
  onkeydown="handleVinylCardKeydown(event, this)"
  role="button"
  tabindex="0"
  aria-label={`${vinyl.title} par ${vinyl.artist}${vinyl.year ? `, ${vinyl.year}` : ''}. Cliquer pour ouvrir la page du vinyle`}
>
  <!-- Image de couverture -->
  <div class="aspect-square relative glass dark:glass-dark">
    <img
      src={vinyl.coverImage || defaultCover}
      alt={`Couverture de ${vinyl.title}`}
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.src='/default-vinyl-cover.svg'"
    />
    {
      vinyl.condition && (
        <div class="absolute top-1 right-1">
          <span class="bg-black bg-opacity-70 text-white text-xs px-1.5 py-0.5 rounded text-[10px] leading-none">
            {vinyl.condition}
          </span>
        </div>
      )
    }

    <!-- Actions - Desktop (hover) -->
    {
      (showActions || showViewOnly) && (
        <div class="hidden md:flex absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-50 transition-all duration-300 items-center justify-center opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto">
          <div class="flex gap-2 items-center justify-center w-full h-full">
            {showActions && (
              <>
                <!-- Bouton Éditer -->
                <button
                  class="bg-blue-500 hover:bg-blue-600 text-white p-2 rounded-full transition-colors shadow-lg flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-blue-300 focus:ring-offset-2"
                  title="Éditer le vinyle"
                  data-vinyl-id={vinyl.id || ''}
                  data-action="edit"
                  aria-label={`Éditer ${vinyl.title} par ${vinyl.artist}`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                    />
                  </svg>
                </button>
                
                <!-- Bouton Supprimer -->
                <button
                  class="bg-red-500 hover:bg-red-600 text-white p-2 rounded-full transition-colors shadow-lg flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2"
                  title="Supprimer de la collection"
                  data-vinyl-id={vinyl.id || ''}
                  data-vinyl-title={vinyl.title || ''}
                  data-vinyl-artist={vinyl.artist || ''}
                  data-vinyl-year={vinyl.year || ''}
                  data-vinyl-format={vinyl.format || ''}
                  data-vinyl-condition={vinyl.condition || ''}
                  data-vinyl-price={vinyl.price || 0}
                  data-vinyl-cover={vinyl.coverImage || '/default-vinyl-cover.svg'}
                  data-action="delete"
                  aria-label={`Supprimer ${vinyl.title} par ${vinyl.artist} de votre collection`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 6h5l.645-1.69A2 2 0 0 1 10.53 4h2.94a2 2 0 0 1 1.885 1.31L15 6h5"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 11v6"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M14 11v6"
                    />
                  </svg>
                </button>
              </>
            )}
          </div>
        </div>
      )
    }
  </div>

  <!-- Informations du vinyle -->
  <div class="p-2 sm:p-3">
    <!-- Titre avec boutons mobiles à côté -->
    <div class="flex items-start justify-between gap-1 mb-1">
      <h3
        class="font-medium text-neutral-900 dark:text-neutral-50 text-sm sm:text-base line-clamp-2 flex-1"
      >
        {vinyl.title}
      </h3>

      <!-- Bouton supprimer mobile à côté du titre -->
      {
        showActions && (
          <div class="md:hidden flex gap-1 flex-shrink-0">
            <button
              class="bg-red-500 hover:bg-red-600 hover:bg-opacity-90 text-white p-0.5 xs:p-1 rounded-full transition-colors shadow-sm flex items-center justify-center"
              title="Supprimer de la collection"
              data-vinyl-id={vinyl.id || ''}
              data-vinyl-title={vinyl.title || ''}
              data-vinyl-artist={vinyl.artist || ''}
              data-vinyl-year={vinyl.year || ''}
              data-vinyl-format={vinyl.format || ''}
              data-vinyl-condition={vinyl.condition || ''}
              data-vinyl-price={vinyl.price || 0}
              data-vinyl-cover={vinyl.coverImage || '/default-vinyl-cover.svg'}
              data-action="delete"
            >
              <svg
                class="w-2.5 h-2.5 xs:w-3 xs:h-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 6h5l.645-1.69A2 2 0 0 1 10.53 4h2.94a2 2 0 0 1 1.885 1.31L15 6h5"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 11v6"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 11v6"
                />
              </svg>
            </button>
          </div>
        )
      }
    </div>

    <!-- Artiste -->
    <p class="text-neutral-600 dark:text-neutral-400 text-xs sm:text-sm line-clamp-1 mb-2">
      {vinyl.artist}
    </p>

    <!-- Détails -->
    <div class="flex items-center justify-between text-xs text-neutral-500 dark:text-neutral-500">
      <div class="flex items-center gap-2">
        {
          vinyl.year && (
            <span class="bg-neutral-100 dark:bg-neutral-800 px-1.5 py-0.5 rounded text-[10px]">
              {vinyl.year}
            </span>
          )
        }
        {
          vinyl.format && (
            <span class="bg-neutral-100 dark:bg-neutral-800 px-1.5 py-0.5 rounded text-[10px]">
              {vinyl.format}
            </span>
          )
        }
      </div>
      {
        vinyl.price && (
          <span class="hidden md:inline font-medium text-emerald-600 dark:text-emerald-400">
            {vinyl.price.toFixed(0)}€
          </span>
        )
      }
    </div>

    {/* Composants d'interaction utilisateur - version compacte */}
    {showActions && (
      <div class="flex items-center justify-between gap-2 mt-2 pt-2 border-t border-neutral-200/50 dark:border-neutral-700/50">
        <ListenedCheckbox 
          vinylId={vinyl.id}
          listened={vinyl.listened || false}
          listenedAt={vinyl.listenedAt ? vinyl.listenedAt.toString() : null}
          size="sm"
          showLabel={false}
        />
        
        <StarRating 
          vinylId={vinyl.id}
          rating={vinyl.userRating || 0}
          size="sm"
          class="flex-1 justify-end"
        />
      </div>
    )}
  </div>
</div>

<style>
  .line-clamp-1 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .line-clamp-2 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
</style>

<script>
  // Fonction pour gérer le clic sur la carte
  function handleVinylCardClick(event: Event, card: HTMLElement) {
    // Empêcher le clic si on clique sur un bouton
    const button = (event.target as HTMLElement).closest('button')
    if (button) {
      return // Laisser le bouton gérer son propre clic
    }

    // Empêcher le clic si on clique sur la zone d'actions hover (desktop uniquement)
    const actionsOverlay = (event.target as HTMLElement).closest('.group-hover\\:pointer-events-auto')
    if (actionsOverlay && window.innerWidth >= 768) {
      return
    }

    // Rediriger vers la page de détail du vinyle sur tous les appareils
    const vinylId = card.getAttribute('data-vinyl-id')
    if (!vinylId) return

    console.log('🖱️ Clic sur carte compact, redirection vers:', vinylId)
    window.location.href = `/vinyl/${vinylId}`
  }

  // Fonction pour gérer les événements clavier sur les cartes
  function handleVinylCardKeydown(event: KeyboardEvent, card: HTMLElement) {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault()
      handleVinylCardClick(event, card)
    }
  }

  // Exposer les fonctions globalement
  ;(window as any).handleVinylCardClick = handleVinylCardClick
  ;(window as any).handleVinylCardKeydown = handleVinylCardKeydown

  // Gestion des actions sur les cartes compactes de vinyles
  document.addEventListener('DOMContentLoaded', () => {
    const actionButtons = document.querySelectorAll('[data-action]')

    actionButtons.forEach((button) => {
      button.addEventListener('click', async (e) => {
        e.preventDefault()
        e.stopPropagation()

        const target = (e.target as HTMLElement).closest('button') as HTMLButtonElement
        if (!target) return
        
        const action = target.dataset.action
        const vinylId = target.dataset.vinylId

        if (!action || !vinylId) return

        try {
          switch (action) {
            case 'edit':
              // Rediriger vers la page d'édition du vinyle
              console.log("✏️ Redirection vers l'édition pour:", vinylId)
              window.location.href = `/vinyl/${vinylId}`
              break
            case 'delete':
              // Récupérer les informations du vinyle depuis les attributs data-*
              const vinyl = {
                id: vinylId,
                title: target.dataset.vinylTitle || 'Titre inconnu',
                artist: target.dataset.vinylArtist || 'Artiste inconnu',
                year: target.dataset.vinylYear || '',
                format: target.dataset.vinylFormat || '',
                condition: target.dataset.vinylCondition || '',
                price: parseFloat(target.dataset.vinylPrice || '0'),
                coverImage: target.dataset.vinylCover || '/default-vinyl-cover.svg',
              }

              // Ouvrir la modal de confirmation
              const openDeleteModal = (window as unknown as Record<string, unknown>)
                .openDeleteVinylModal as
                | ((vinyl: {
                    id: string
                    title: string
                    artist: string
                    year: string
                    format: string
                    condition: string
                    price: number
                    coverImage: string
                  }) => void)
                | undefined

              if (typeof openDeleteModal === 'function') {
                openDeleteModal(vinyl)
              } else {
                console.error('Modal de suppression non disponible')
                // Attendre que la modal soit chargée
                setTimeout(() => {
                  const retryOpenDeleteModal = (window as unknown as Record<string, unknown>)
                    .openDeleteVinylModal as
                    | ((vinyl: {
                        id: string
                        title: string
                        artist: string
                        year: string
                        format: string
                        condition: string
                        price: number
                        coverImage: string
                      }) => void)
                    | undefined

                  if (typeof retryOpenDeleteModal === 'function') {
                    retryOpenDeleteModal(vinyl)
                  } else {
                    // Dernier recours avec confirm
                    if (
                      confirm(`Êtes-vous sûr de vouloir supprimer "${vinyl.title}" de votre collection ?`)
                    ) {
                      deleteVinyl(vinylId)
                    }
                  }
                }, 100)
              }
              break
          }
        } catch (error) {
          console.error("Erreur lors de l'action:", error)
          alert('Une erreur est survenue. Veuillez réessayer.')
        }
      })
    })
  })

  async function deleteVinyl(vinylId: string) {
    try {
      const response = await fetch('/api/collections/remove', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({ vinylId }),
      })

      const data = await response.json()

      if (data.success) {
        // Recharger la page pour voir les changements
        window.location.reload()
      } else {
        console.error('Erreur lors de la suppression :', data.error || 'Erreur inconnue')
        // Recharger la page même en cas d'erreur pour éviter l'état inconsistant
        window.location.reload()
      }
    } catch (error) {
      console.error('Erreur de connexion :', error)
      // Recharger la page en cas d'erreur de connexion
      window.location.reload()
    }
  }
</script>
