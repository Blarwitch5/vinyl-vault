---
export interface Props {
  id: string
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full'
  closable?: boolean
  backdrop?: 'blur' | 'dark' | 'none'
  animation?: 'fade' | 'scale' | 'slide'
  zIndex?: number
  className?: string
}

const {
  id,
  size = 'md',
  closable = true,
  backdrop = 'blur',
  animation = 'fade',
  zIndex = 9999,
  className = '',
} = Astro.props

// Classes pour les tailles
const sizeClasses = {
  sm: 'max-w-sm',
  md: 'max-w-md',
  lg: 'max-w-lg',
  xl: 'max-w-xl',
  full: 'max-w-full',
}

// Classes pour le backdrop
const backdropClasses = {
  blur: 'bg-black/70 backdrop-blur-sm',
  dark: 'bg-black/80',
  none: 'bg-transparent',
}

// Classes pour l'animation
const animationClasses = {
  fade: 'transition-opacity duration-300',
  scale: 'transition-all duration-300',
  slide: 'transition-transform duration-300',
}
---

<div
  {id}
  class={`modal-overlay fixed inset-0 ${backdropClasses[backdrop]} items-center justify-center p-2 sm:p-4 hidden ${animationClasses[animation]}`}
  style={`z-index: ${zIndex}`}
  data-modal-id={id}
  data-animation={animation}
  data-closable={closable}
>
  <div
    class={`modal-content glass-card dark:glass-dark rounded-lg ${sizeClasses[size]} w-full mx-2 sm:mx-4 ${className} ${animation === 'scale' ? 'transform scale-95' : ''} ${animation === 'slide' ? 'transform translate-y-4' : ''}`}
    onclick="event.stopPropagation()"
    data-modal-content
  >
    <!-- Header avec bouton de fermeture optionnel -->
    <div
      class="modal-header flex items-center justify-between p-4 sm:p-6 border-b border-neutral-200 dark:border-white/10"
    >
      <div class="modal-title">
        <slot name="title" />
      </div>
      {
        closable && (
          <button
            class="modal-close-btn text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors p-1 flex items-center justify-center"
            data-modal-close
            aria-label="Fermer la modal"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M18 6 6 18"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="m6 6 12 12"
              />
            </svg>
          </button>
        )
      }
    </div>

    <!-- Contenu principal -->
    <div class="modal-body p-4 sm:p-6">
      <slot />
    </div>

    <!-- Footer optionnel -->
    <div class="modal-footer border-t border-neutral-200 dark:border-white/10 p-4 sm:p-6">
      <slot name="footer" />
    </div>
  </div>
</div>

<script>
  import { modalManager } from '../../utils/modal-manager'

  // Auto-initialisation des modales
  document.addEventListener('DOMContentLoaded', () => {
    const modals = document.querySelectorAll('[data-modal-id]')

    modals.forEach((modal) => {
      const modalElement = modal as HTMLElement
      const modalId = modalElement.dataset.modalId
      const isClosable = modalElement.dataset.closable === 'true'
      const animation = modalElement.dataset.animation || 'fade'

      if (modalId) {
        // Enregistrer la modal avec le gestionnaire
        modalManager.registerModal(modalId, modalElement)

        // Ajouter les événements de fermeture
        if (isClosable) {
          // Fermeture par clic sur le backdrop
          modalElement.addEventListener('click', (e) => {
            if (e.target === modalElement) {
              modalManager.closeModal(modalId)
            }
          })

          // Fermeture par bouton close
          const closeBtn = modalElement.querySelector('[data-modal-close]')
          if (closeBtn) {
            closeBtn.addEventListener('click', () => {
              modalManager.closeModal(modalId)
            })
          }

          // Fermeture par Escape
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modalManager.getCurrentModal() === modalId) {
              modalManager.closeModal(modalId)
            }
          })
        }

        // Événements personnalisés pour l'ouverture/fermeture
        modalElement.addEventListener('modal:open', () => {
          // Émettre un événement personnalisé
          modalElement.dispatchEvent(
            new CustomEvent('modal:opened', {
              detail: { modalId },
            })
          )
        })

        modalElement.addEventListener('modal:close', () => {
          // Émettre un événement personnalisé
          modalElement.dispatchEvent(
            new CustomEvent('modal:closed', {
              detail: { modalId },
            })
          )
        })
      }
    })
  })

  // Fonctions utilitaires globales
  ;(window as any).openModal = function (modalId: string) {
    modalManager.openModal(modalId)
  }
  ;(window as any).closeModal = function (modalId: string) {
    modalManager.closeModal(modalId)
  }
  ;(window as any).toggleModal = function (modalId: string) {
    if (modalManager.getCurrentModal() === modalId) {
      modalManager.closeModal(modalId)
    } else {
      modalManager.openModal(modalId)
    }
  }
</script>

<style>
  /* Animations personnalisées */
  .modal-overlay[data-animation='scale'] .modal-content {
    transition:
      transform 300ms ease-out,
      opacity 300ms ease-out;
  }

  .modal-overlay[data-animation='slide'] .modal-content {
    transition:
      transform 300ms ease-out,
      opacity 300ms ease-out;
  }

  /* États d'animation */
  .modal-overlay.modal-opening[data-animation='scale'] .modal-content {
    transform: scale(1);
    opacity: 1;
  }

  .modal-overlay.modal-opening[data-animation='slide'] .modal-content {
    transform: translateY(0);
    opacity: 1;
  }

  .modal-overlay.modal-closing[data-animation='scale'] .modal-content {
    transform: scale(0.95);
    opacity: 0;
  }

  .modal-overlay.modal-closing[data-animation='slide'] .modal-content {
    transform: translateY(16px);
    opacity: 0;
  }
</style>
