---
export interface Props {
  vinyl: {
    id: string
    title: string
    artist: string
    year?: number
    format?: string
    coverImage?: string
    condition?: string
    price?: number
    note?: string
    discogsId?: string
    discogsUrl?: string
    genre?: string
    label?: string
    country?: string
    catalogNumber?: string
    barcode?: string
    tracks?: string
    rating?: number
    ratingCount?: number
  }
  showActions?: boolean
  isInCollection?: boolean
  compactActions?: boolean
}

const { vinyl, showActions = false, isInCollection = false, compactActions = false } = Astro.props
const defaultCover = '/default-vinyl-cover.svg'

// Déterminer si c'est un vinyle de la base de données locale ou de Discogs
// Les IDs de la base locale sont des UUIDs (format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
// Les IDs Discogs sont des nombres
const isLocalVinyl =
  vinyl.id && /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(vinyl.id)
---

<!-- Pre-fetch de la page de détail du vinyle (seulement pour les vinyles locaux) -->{
  isLocalVinyl && <link rel="prefetch" href={`/vinyl/${vinyl.id}`} />
}

<div
  class="vinyl-card-container glass dark:glass-dark dark:bg-neutral-950 dark:bg-gradient-emerald-subtle rounded-lg sm:rounded-xl shadow-md dark:shadow-white-md overflow-hidden hover:shadow-lg dark:hover:shadow-white-lg transition-all duration-300 hover:-translate-y-1 group"
  data-vinyl-id={vinyl.id}
  data-discogs-id={vinyl.discogsId}
  data-discogs-url={vinyl.discogsUrl}
  data-genre={vinyl.genre}
  data-label={vinyl.label}
  data-country={vinyl.country}
  data-catalog={vinyl.catalogNumber}
  data-barcode={vinyl.barcode}
  data-condition={vinyl.condition}
  data-price={vinyl.price}
  data-note={vinyl.note}
>
  <!-- Image de couverture -->
  <div class="aspect-square relative glass dark:glass-dark">
    <img
      src={vinyl.coverImage || defaultCover}
      alt={`Couverture de ${vinyl.title}`}
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.src='/default-vinyl-cover.svg'"
    />
    {
      vinyl.condition && (
        <div class="absolute top-2 right-2">
          <span class="bg-black bg-opacity-70 text-white text-xs px-2 py-1 rounded-full">
            {vinyl.condition}
          </span>
        </div>
      )
    }

    <!-- Actions compactes avec icônes - Desktop (hover) -->
    {
      showActions && (
        <div class="hidden md:block absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-50 transition-all duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto">
          <div class="flex gap-2 items-center justify-center w-full h-full">
            <button
              class="bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 p-2 rounded-full hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors shadow-lg flex items-center justify-center"
              data-vinyl-id={vinyl.id}
              data-action="preview-vinyl"
              title="Voir les détails"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-4 h-4"
              >
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
            {!isInCollection ? (
              <button
                class="bg-gradient-emerald hover:bg-gradient-emerald/80 text-white p-2 rounded-full transition-colors shadow-lg flex items-center justify-center"
                data-vinyl-id={vinyl.id}
                data-action="add-to-collection"
                title="Ajouter à la collection"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-4 h-4"
                >
                  <path d="M12 5v14" />
                  <path d="M5 12h14" />
                </svg>
              </button>
            ) : (
              <button
                class="bg-red-500 hover:bg-red-600 hover:bg-opacity-90 text-white p-2 rounded-full transition-colors shadow-lg flex items-center justify-center"
                data-vinyl-id={vinyl.id}
                data-action="remove-from-collection"
                title="Supprimer de la collection"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 6h5l.645-1.69A2 2 0 0 1 10.53 4h2.94a2 2 0 0 1 1.885 1.31L15 6h5"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 11v6"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 11v6"
                  />
                </svg>
              </button>
            )}
          </div>
        </div>
      )
    }
  </div>

  <!-- Informations du vinyle -->
  <div class="p-3 sm:p-4">
    <!-- Titre avec boutons mobiles à côté -->
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3
        class="font-semibold text-base sm:text-lg text-neutral-900 dark:text-neutral-50 line-clamp-2 flex-1"
        data-vinyl-title
      >
        {vinyl.title}
      </h3>

      <!-- Boutons mobiles à côté du titre -->
      <div class="md:hidden flex gap-1 flex-shrink-0">
        <button
          class="bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 p-1.5 rounded-full hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors shadow-sm flex items-center justify-center"
          data-vinyl-id={vinyl.id}
          data-action="preview-vinyl"
          title="Voir les détails"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-3 h-3"
          >
            <path
              d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
            ></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </button>
        {
          !isInCollection ? (
            <button
              class="bg-gradient-emerald hover:bg-gradient-emerald/80 text-white p-1.5 rounded-full transition-colors shadow-sm flex items-center justify-center"
              data-vinyl-id={vinyl.id}
              data-action="add-to-collection"
              title="Ajouter à la collection"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-3 h-3"
              >
                <path d="M12 5v14" />
                <path d="M5 12h14" />
              </svg>
            </button>
          ) : (
            <button
              class="bg-red-500 hover:bg-red-600 hover:bg-opacity-90 text-white p-1.5 rounded-full transition-colors shadow-sm flex items-center justify-center"
              data-vinyl-id={vinyl.id}
              data-action="remove-from-collection"
              title="Supprimer de la collection"
            >
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 6h5l.645-1.69A2 2 0 0 1 10.53 4h2.94a2 2 0 0 1 1.885 1.31L15 6h5"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 11v6"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 11v6"
                />
              </svg>
            </button>
          )
        }
      </div>
    </div>

    <p
      class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400 mb-2 line-clamp-1"
      data-vinyl-artist
    >
      {vinyl.artist}
    </p>

    <div
      class="flex items-center justify-between text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 mb-3"
    >
      {
        vinyl.year && (
          <span data-vinyl-year class="font-mono">
            {vinyl.year}
          </span>
        )
      }
      {vinyl.format && <span>{vinyl.format}</span>}
    </div>

    {
      vinyl.price && (
        <div class="hidden md:block text-base sm:text-lg font-bold text-emerald-600 dark:text-gradient-emerald mb-3 font-mono">
          {vinyl.price.toFixed(2)} €
        </div>
      )
    }

    {
      vinyl.note && (
        <p class="text-sm text-neutral-600 dark:text-neutral-400 italic mb-3 line-clamp-2">
          "{vinyl.note}"
        </p>
      )
    }
  </div>
</div>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Améliorations pour les modales sur mobile */
  @media (max-width: 640px) {
    /* Assurer que les modales sont visibles sur mobile */
    #vinyl-preview-modal,
    #add-to-collection-modal {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      z-index: 9999 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 8px !important;
    }

    /* Ajuster la taille des modales sur mobile */
    #vinyl-preview-modal .glass-card,
    #add-to-collection-modal .glass-card {
      width: 100% !important;
      max-width: calc(100vw - 16px) !important;
      max-height: calc(100vh - 16px) !important;
      margin: 0 !important;
    }

    /* Ajuster les boutons sur mobile */
    #add-from-preview {
      font-size: 12px !important;
      padding: 8px 12px !important;
    }

    /* Ajuster l'en-tête sur mobile */
    #vinyl-preview-modal .flex.items-center.justify-between {
      flex-direction: column !important;
      gap: 12px !important;
      align-items: stretch !important;
    }

    #vinyl-preview-modal .flex.items-center.gap-3 {
      justify-content: space-between !important;
      width: 100% !important;
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Import du gestionnaire de modales et des utilitaires
  import { resetButton, setButtonLoading } from '../utils/button-helpers'
  import { modalManager } from '../utils/modal-manager'
  import {
    showDuplicateModal,
    showErrorModal,
    showSuccessModal,
  } from '../utils/notification-modals'
  import {
    checkForDuplicate,
    enrichVinylDataWithDiscogs,
    extractDataFromPreviewModal,
    extractVinylDataFromCard,
  } from '../utils/vinyl-data-extractor'

  // Gestion des actions sur les cartes de vinyles
  document.addEventListener('DOMContentLoaded', () => {
    const actionButtons = document.querySelectorAll('[data-action]')

    actionButtons.forEach((button) => {
      button.addEventListener('click', async (e) => {
        e.preventDefault()
        const target = e.target as HTMLButtonElement
        const action = target.dataset.action
        const vinylId = target.dataset.vinylId

        if (!action || !vinylId) return

        try {
          switch (action) {
            case 'add-to-collection':
              await openAddToCollectionModal(vinylId, target)
              break
            case 'preview-vinyl':
              console.log("👁️ Ouverture de la modal d'aperçu pour:", vinylId)
              await openVinylPreviewModal(vinylId, target)
              break
            case 'remove':
              // Récupérer les informations du vinyle depuis la carte
              const card = target.closest('.vinyl-card-container')
              if (!card) return

              const vinyl = {
                id: vinylId,
                title: card.querySelector('[data-vinyl-title]')?.textContent || 'Vinyle inconnu',
                artist: card.querySelector('[data-vinyl-artist]')?.textContent || 'Artiste inconnu',
                year: card.querySelector('[data-vinyl-year]')?.textContent || '',
                format:
                  Array.from(card.querySelectorAll('span')).find(
                    (span) =>
                      span.textContent?.includes('LP') ||
                      span.textContent?.includes('EP') ||
                      span.textContent?.includes('Single')
                  )?.textContent || '',
                coverImage: card.querySelector('img')?.src || '/default-vinyl-cover.svg',
              }

              // Ouvrir la modal de confirmation
              if (typeof (window as any).openDeleteVinylModal === 'function') {
                ;(window as any).openDeleteVinylModal(vinyl)
              } else {
                console.error('Modal de suppression non disponible')
                // Attendre que la modal soit chargée
                setTimeout(() => {
                  if (typeof (window as any).openDeleteVinylModal === 'function') {
                    ;(window as any).openDeleteVinylModal(vinyl)
                  } else {
                    // Dernier recours avec confirm
                    if (
                      confirm(
                        `Êtes-vous sûr de vouloir supprimer "${vinyl.title}" de votre collection ?`
                      )
                    ) {
                      removeFromCollection(vinylId)
                    }
                  }
                }, 100)
              }
              break
          }
        } catch (error) {
          console.error("Erreur lors de l'action:", error)
          alert('Une erreur est survenue. Veuillez réessayer.')
        }
      })
    })
  })

  async function openVinylPreviewModal(vinylId: string, button: HTMLButtonElement) {
    console.log('🔍 openVinylPreviewModal appelée avec vinylId:', vinylId)

    // Récupérer les informations du vinyle depuis la carte
    const card = button.closest('.vinyl-card-container')
    if (!card) {
      console.error('❌ Carte du vinyle non trouvée')
      return
    }

    console.log('📋 Carte trouvée:', card)
    console.log('📋 data-vinyl-id:', card.getAttribute('data-vinyl-id'))
    console.log('📋 data-discogs-id:', card.getAttribute('data-discogs-id'))

    // Pour les vinyles de recherche, l'ID est en fait le discogsId
    // Pour les vinyles en collection, on a un data-discogs-id séparé
    const discogsId = card.getAttribute('data-discogs-id') || vinylId
    console.log('🎯 Discogs ID final:', discogsId)

    if (!discogsId) {
      console.error('❌ Discogs ID non trouvé')
      return
    }

    // Créer la modal d'aperçu si elle n'existe pas
    let modal = document.getElementById('vinyl-preview-modal')
    if (!modal) {
      modal = document.createElement('div')
      modal.id = 'vinyl-preview-modal'
      modal.className =
        'modal-overlay fixed inset-0 bg-black/70 backdrop-blur-sm z-[9999] items-center justify-center p-2 sm:p-4 hidden'
      modal.innerHTML = `
          <div class="modal-content glass-card dark:glass-dark rounded-lg max-w-sm sm:max-w-md md:max-w-2xl lg:max-w-4xl w-full max-h-[95vh] sm:max-h-[90vh] overflow-y-auto mx-2 sm:mx-4" onclick="event.stopPropagation()">
            <div class="flex items-center justify-between p-6 border-b border-neutral-200 dark:border-white/10">
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50">
                Aperçu du vinyle
              </h3>
              <div class="flex items-center gap-3">
                <button id="add-from-preview" class="bg-gradient-emerald text-white px-4 py-2 rounded-lg hover:bg-gradient-emerald/80 transition-colors text-sm font-medium flex items-center justify-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14"/>
                    <path d="M5 12h14"/>
                  </svg>
                  Ajouter à ma collection
                </button>
                <button id="close-preview-modal" class="text-gray-400 hover:text-neutral-600 dark:hover:text-gray-300 p-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-icon lucide-x">
                    <path d="M18 6 6 18"/>
                    <path d="m6 6 12 12"/>
                  </svg>
                </button>
              </div>
            </div>
            <div id="preview-content" class="p-6">
              <div class="text-center">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-500 mx-auto mb-4"></div>
                <p class="text-neutral-600 dark:text-neutral-400">Chargement des détails...</p>
            </div>
          </div>
        </div>
      `
      document.body.appendChild(modal)

      // Ajouter les event listeners
      document
        .getElementById('close-preview-modal')
        ?.addEventListener('click', hideVinylPreviewModal)
      document.getElementById('add-from-preview')?.addEventListener('click', async () => {
        // Extraire les données de base depuis la carte
        const baseVinylData = extractVinylDataFromCard(card, discogsId)

        // Extraire les données supplémentaires depuis la modal d'aperçu
        const previewData = extractDataFromPreviewModal()

        // Combiner toutes les données
        const combinedData = {
          ...baseVinylData,
          ...previewData, // Les données de la modal d'aperçu ont la priorité
        }

        // Enrichir avec les données Discogs complètes (au cas où il y aurait encore des infos manquantes)
        const enrichedVinylData = await enrichVinylDataWithDiscogs(combinedData)

        // Vérifier d'abord s'il y a un doublon
        const duplicateCheck = await checkForDuplicate(enrichedVinylData)
        if (duplicateCheck.exists) {
          console.log("🚫 Doublon détecté depuis la modal d'aperçu")
          hideVinylPreviewModal()
          showDuplicateModal(enrichedVinylData, duplicateCheck.vinyl)
          return
        }

        hideVinylPreviewModal()

        // Utiliser le système unifié de modal d'ajout avec données complètes
        document.dispatchEvent(
          new CustomEvent('modal:add-to-collection:open', {
            detail: { vinylData: enrichedVinylData },
          })
        )
      })
      // La fermeture au clic extérieur est gérée par le ModalManager
    }

    // Afficher la modal
    const previewModal = document.getElementById('vinyl-preview-modal')

    if (previewModal) {
      modalManager.registerModal('vinyl-preview', previewModal)
      modalManager.openModal('vinyl-preview')
    } else {
      console.error('❌ Modal preview non trouvée après création')
    }

    // Charger les détails du vinyle
    await loadVinylPreviewDetails(discogsId)
  }

  function hideVinylPreviewModal() {
    modalManager.closeModal('vinyl-preview')
  }

  async function loadVinylPreviewDetails(discogsId: string) {
    const content = document.getElementById('preview-content')
    if (!content) return

    try {
      // Récupérer les détails du vinyle depuis l'API Discogs
      const response = await fetch(`/api/discogs/release/${discogsId}`)

      if (!response.ok) {
        throw new Error('Erreur lors de la récupération des détails')
      }

      const vinylDetails = await response.json()

      // Afficher les détails du vinyle
      displayVinylPreview(vinylDetails, content)
    } catch (error) {
      console.error('Erreur lors du chargement des détails:', error)
      content.innerHTML = `
        <div class="text-center">
          <div class="mb-4">
            <svg class="w-16 h-16 text-red-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
          </div>
          <h4 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50 mb-2">
            Erreur de chargement
          </h4>
          <p class="text-neutral-600 dark:text-neutral-400 mb-6">
            Impossible de charger les détails du vinyle.
          </p>
          <button onclick="hideVinylPreviewModal()" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600">
            Fermer
          </button>
        </div>
      `
    }
  }

  function displayVinylPreview(vinyl: any, content: HTMLElement) {
    const artists = vinyl.artists?.map((a: any) => a.name).join(', ') || 'Artiste inconnu'
    const genres = vinyl.genres?.join(', ') || ''
    const styles = vinyl.styles?.join(', ') || ''
    const year = vinyl.year || vinyl.released?.split('-')[0] || ''
    const country = vinyl.country || ''
    const label = vinyl.labels?.[0]?.name || ''
    const catalogNumber = vinyl.labels?.[0]?.catno || ''
    const format = vinyl.formats?.[0]?.name || 'Vinyl'
    const rating = vinyl.community?.rating?.average || 0
    const ratingCount = vinyl.community?.rating?.count || 0
    const notes = vinyl.notes || ''

    // Tracks
    const tracks = vinyl.tracklist || []
    const tracksHtml =
      tracks.length > 0
        ? `
      <div class="mt-6">
        <h4 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50 mb-4">
          Pistes (${tracks.length})
        </h4>
        <div class="space-y-2 max-h-64 overflow-y-auto">
          ${tracks
            .map(
              (track: any, index: number) => `
            <div class="flex items-center justify-between p-3 bg-neutral-50 dark:bg-neutral-800 rounded-lg">
              <div class="flex items-center space-x-3">
                <span class="text-sm font-mono text-neutral-500 dark:text-neutral-400 w-8">
                  ${track.position || index + 1}
                </span>
                <span class="text-neutral-900 dark:text-neutral-50">
                  ${track.title}
                </span>
              </div>
              ${track.duration ? `<span class="text-sm text-neutral-500 dark:text-neutral-400 font-mono">${track.duration}</span>` : ''}
            </div>
          `
            )
            .join('')}
        </div>
      </div>
    `
        : ''

    content.innerHTML = `
      <div class="space-y-6">
        <!-- Informations principales -->
        <div class="flex flex-col lg:flex-row gap-6">
          <!-- Image -->
          <div class="flex-shrink-0">
            <img 
              src="${vinyl.images?.[0]?.uri || '/default-vinyl-cover.svg'}" 
              alt="${vinyl.title}"
              class="w-64 h-64 lg:w-80 lg:h-80 rounded-lg object-cover shadow-lg"
              onerror="this.src='/default-vinyl-cover.svg'"
            />
          </div>
          
          <!-- Détails -->
          <div class="flex-1 space-y-4">
            <div>
              <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-50 mb-2">
                ${vinyl.title}
              </h2>
              <p class="text-lg text-neutral-600 dark:text-neutral-400">
                ${artists}
              </p>
            </div>

