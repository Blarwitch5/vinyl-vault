  ;(window as any).hideVinylPreviewModal = hideVinylPreviewModal

  // Fonctions utilitaires déplacées vers src/utils/vinyl-data-extractor.ts

  async function openAddToCollectionModal(vinylId: string, button: HTMLButtonElement) {
    // Récupérer les informations du vinyle depuis la carte
    const card = button.closest('.vinyl-card-container')
    if (!card) return

    // Extraire les données de base depuis la carte
    const baseVinylData = extractVinylDataFromCard(card, vinylId)

    // Afficher un indicateur de chargement sur le bouton
    const originalText = setButtonLoading(button, 'Enrichissement...')

    try {
      // Enrichir avec les données Discogs si possible
      const enrichedVinylData = await enrichVinylDataWithDiscogs(baseVinylData)

      // Utiliser le système unifié de modal d'ajout
      document.dispatchEvent(
        new CustomEvent('modal:add-to-collection:open', {
          detail: { vinylData: enrichedVinylData },
        })
      )
    } finally {
      // Restaurer le bouton
      resetButton(button, originalText)
    }
  }

  // Nouvelle fonction qui utilise les données complètes du vinyle
  ;(window as any).addToCollectionWithData = async function (
    collectionId: string,
    collectionName: string,
    vinylData: any
  ) {
    try {
      console.log('addToCollectionWithData: Données du vinyle:', vinylData)

      // Vérifier d'abord s'il y a un doublon
      const duplicateCheck = await checkForDuplicate(vinylData)
      if (duplicateCheck.exists) {
        console.log("🚫 Doublon détecté, affichage de la modal d'information")
        showDuplicateModal(vinylData, duplicateCheck.vinyl)
        return
      }

      const response = await fetch('/api/collections/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({
          collection_id: collectionId,
          vinyl_data: {
            title: vinylData.title,
            artist: vinylData.artist,
            year: vinylData.year,
            format: vinylData.format,
            condition: vinylData.condition,
            price: vinylData.price,
            note: vinylData.note,
            coverImage: vinylData.coverImage,
            discogsId: vinylData.discogsId,
            discogsUrl: vinylData.discogsUrl,
            barcode: vinylData.barcode,
            tracks: vinylData.tracks,
            genre: vinylData.genre,
          },
        }),
      })

      if (response.ok) {
        showSuccessModal(
          'Vinyle ajouté !',
          `Le vinyle a été ajouté à votre collection "${collectionName}".`,
          [
            {
              text: 'Voir ma collection',
              href: '/dashboard',
              primary: true,
            },
          ]
        )
      } else {
        const errorData = await response.json()
        console.error('Erreur API:', errorData)
        throw new Error(errorData.details || errorData.error || "Erreur lors de l'ajout")
      }
    } catch (error) {
      console.error('Erreur:', error)
      const errorMessage =
        error instanceof Error ? error.message : "Erreur lors de l'ajout du vinyle"
      showErrorModal("Erreur d'ajout", errorMessage)
    }
  }

