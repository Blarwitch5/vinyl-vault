  ;(window as any).createCollectionAndAdd = async function (vinylId: string) {
    const name = prompt('Nom de la collection:')
    if (!name || name.trim() === '') return

    try {
      // Créer la collection
      const response = await fetch('/api/collections/create', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({ name: name.trim(), description: '' }),
      })

      if (response.ok) {
        const result = await response.json()
        console.log('Collection créée:', result.collection)

        // Maintenant ajouter le vinyle à cette nouvelle collection
        // Récupérer les données du vinyle depuis le DOM
        const card = document.querySelector(`[data-vinyl-id="${vinylId}"]`)
        if (!card) {
          throw new Error('Carte du vinyle non trouvée')
        }

        // Utiliser la fonction utilitaire pour extraire toutes les données
        const vinylData = extractVinylDataFromCard(card, vinylId)

        // Vérifier d'abord s'il y a un doublon
        const duplicateCheck = await checkForDuplicate(vinylData)
        if (duplicateCheck.exists) {
          console.log("🚫 Doublon détecté, affichage de la modal d'information")
          // Modal fermée automatiquement par le système de gestion de doublons
          showDuplicateModal(vinylData, duplicateCheck.vinyl)
          return
        }

        // Ajouter le vinyle à la nouvelle collection
        const addResponse = await fetch('/api/collections/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: JSON.stringify({
            collection_id: result.collection.id,
            vinyl_data: {
              title: vinylData.title,
              artist: vinylData.artist,
              year: vinylData.year,
              format: vinylData.format,
              condition: vinylData.condition,
              price: vinylData.price,
              note: vinylData.note,
              coverImage: vinylData.coverImage,
              discogsId: vinylData.discogsId,
              discogsUrl: vinylData.discogsUrl,
              barcode: vinylData.barcode,
              tracks: vinylData.tracks,
              genre: vinylData.genre,
            },
          }),
        })

        if (addResponse.ok) {
          showSuccessModal(
            'Collection créée !',
            `Collection "${name.trim()}" créée et vinyle ajouté avec succès.`,
            [
              {
                text: 'Voir ma collection',
                href: '/dashboard',
                primary: true,
              },
            ]
          )
          // Modal gérée par le système unifié
        } else {
          const errorData = await addResponse.json()
          throw new Error(
            errorData.details || errorData.error || "Erreur lors de l'ajout du vinyle"
          )
        }
      } else {
        const errorData = await response.json()
        throw new Error(errorData.error || 'Erreur lors de la création de la collection')
      }
    } catch (error) {
      console.error('Erreur:', error)
      const errorMessage =
        error instanceof Error ? error.message : 'Erreur lors de la création de la collection'
      showErrorModal('Erreur de création', errorMessage)
    }
  }

  async function removeFromCollection(vinylId: string) {
    try {
      const response = await fetch('/api/collections/remove', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify({ vinylId }),
      })

      const data = await response.json()

      if (response.ok && data.success) {
        location.reload() // Recharger la page pour voir les changements
      } else {
        showErrorModal(
          'Erreur de suppression',
          data.error || 'Erreur lors de la suppression du vinyle'
        )
      }
    } catch (error) {
      console.error('Erreur lors de la suppression :', error)
      showErrorModal('Erreur de connexion', 'Impossible de se connecter au serveur')
    }
  }
